{
  "providers": {
    "openai-compatible": {
      "baseURL": "https://open.bigmodel.cn/api/paas/v4",
      "apiKey": "${BIGMODEL_API_KEY}"
    }
  },
  "agents": {
    "defaults": {
      "provider": "openai-compatible",
      "model": "glm-5.1",
      "maxTokens": 4096,
      "contextWindowTokens": 65536,
      "temperature": 0.2
    }
  }
}
